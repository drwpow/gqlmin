{
  "name": "gqlmin",
  "version": "0.3.2",
  "description": "< 1 kB GraphQL query minifier",
  "type": "module",
  "packageManager": "pnpm@10.31.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drwpow/gqlmin.git"
  },
  "keywords": [
    "graphql",
    "gql",
    "query",
    "minify",
    "esm",
    "es",
    "modules"
  ],
  "bin": {
    "gqlmin": "bin/cli.js"
  },
  "author": {
    "email": "drew@pow.rs",
    "name": "Drew Powers"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "scripts": {
    "build": "pnpm run \"/^build:.*/\"",
    "build:ts": "tsc",
    "lint": "eslint --ext .js,.ts,.tsx src",
    "test": "vitest run",
    "bench": "vitest bench",
    "version": "pnpm run build"
  },
  "dependencies": {
    "@types/moo": "^0.5.10",
    "moo": "^0.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "chalk": "^5.6.2",
    "eslint": "^10.0.3",
    "execa": "^9.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
